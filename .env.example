# ===================================
# LVC Media Hub — Docker Compose Environment
# Kopiera till .env och fyll i värdena
# ===================================

# PostgreSQL
POSTGRES_USER=lvc
POSTGRES_PASSWORD=ÄNDRA_MIG_till_ett_starkt_lösenord
POSTGRES_DB=lvcmediahub

# Domän — Caddy hanterar auto-HTTPS via Let's Encrypt
# Sätt till :80 för bara HTTP (lokalt/test)
# Sätt till din domän för HTTPS: kvikta.se
SITE_ADDRESS=:80

# Supabase JWT-nycklar — GENERERA MED:
#   node scripts/generate-supabase-keys.js
# Kopiera output hit:
SUPABASE_JWT_SECRET=ÄNDRA_MIG
SUPABASE_ANON_KEY=ÄNDRA_MIG
SUPABASE_SERVICE_ROLE_KEY=ÄNDRA_MIG

# Frontend URL (för Supabase Auth redirects)
FRONTEND_URL=http://localhost:3001
