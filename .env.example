# ===================================
# LVC Media Hub — Docker Compose Environment
# Kopiera till .env och fyll i värdena
# ===================================

# PostgreSQL
POSTGRES_USER=lvc
POSTGRES_PASSWORD=ÄNDRA_MIG_till_ett_starkt_lösenord
POSTGRES_DB=lvcmediahub

# Domän — Caddy hanterar auto-HTTPS via Let's Encrypt
# Sätt till din domän för HTTPS: kvikta.se
# Sätt till :80 för bara HTTP (lokalt)
SITE_ADDRESS=kvikta.se
