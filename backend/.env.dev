# ===================================
# LVC Media Hub — Backend Environment
# ===================================

# Server
NODE_ENV=development
PORT=3001

# Databas (SQLite) — i Docker pekar denna på en monterad volym
DATABASE_URL=file:/app/data/lvc-media-hub.db

# Domain
FRONTEND_URL=http://192.168.1.8:3002
BACKEND_URL=https://lvcmediahub.com

# JWT Secrets — generera med: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=f987147ccb6f010a60b2f83e40beb0035339d770474b949f277d57eb6ab30491b08515d0b5f0929d5d1e4da83b0b4db4b4a434eca24616e07ca04048d5342c1b
JWT_REFRESH_SECRET=7364d6ac8864c61340543dfd5181e4ca08acf60073796b8a58cea1640165b6758274e22ef32ca6d530eaa94070054533c739d983313d331ec8b3aa46f288c891

# CSRF Secret
CSRF_SECRET=5df2fb1158882f5e503dc372fedd0f6addb6aa7e246d6f48f11617e9e3d461df

# Tokens livslängd
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# OpenCloud WebDAV

# Filuppladdning
MAX_FILE_SIZE_BYTES=10737418240
ALLOWED_FILE_TYPES=video/mp4,video/quicktime,video/x-matroska
ALLOWED_EXTENSIONS=.mp4,.mov,.mkv

# Signerade URL:er
SIGNED_URL_EXPIRY_SECONDS=15000

# Admin seed (används vid första körningen)
ADMIN_EMAIL=admin@lvcmediahub.com
ADMIN_PASSWORD=1337elit
ADMIN_NAME=Admin

STREAM_BASE_URL=http://192.168.1.8:3002
STORAGE_PATH=/storage
