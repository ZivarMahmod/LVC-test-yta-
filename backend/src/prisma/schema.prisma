// ===========================================
// LVC Media Hub — Databasschema (Prisma + SQLite)
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("viewer") // admin, uploader, viewer
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  refreshTokens RefreshToken[]
  videos        Video[]
  loginAttempts LoginAttempt[]

  @@index([email])
}

model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  isRevoked   Boolean  @default(false)

  @@index([userId])
  @@index([tokenHash])
}

model Video {
  id            String   @id @default(uuid())
  title         String
  opponent      String
  matchDate     DateTime
  description   String?
  fileName      String
  filePath      String   // Sökväg i OpenCloud, t.ex. /Matcher/2025/2025-03-15_LVC-vs-Norrköping.mp4
  fileSize      BigInt
  mimeType      String
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([matchDate])
  @@index([opponent])
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}
