# ===================================
# LVC Media Hub — Backend Environment
# ===================================

# Server
NODE_ENV=production
PORT=3001

# Databas (SQLite) — i Docker pekar denna på en monterad volym
DATABASE_URL=file:/app/data/lvc-media-hub.db

# Domain
FRONTEND_URL=https://lvcmediahub.com
BACKEND_URL=https://lvcmediahub.com

# JWT Secrets — generera med: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=ÄNDRA_MIG_till_en_lång_slumpmässig_sträng_minst_64_tecken
JWT_REFRESH_SECRET=ÄNDRA_MIG_till_en_annan_lång_slumpmässig_sträng_minst_64_tecken

# CSRF Secret
CSRF_SECRET=ÄNDRA_MIG_till_csrf_secret_minst_32_tecken

# Tokens livslängd
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# OpenCloud WebDAV
OPENCLOUD_WEBDAV_URL=https://din-opencloud-server.se/remote.php/webdav
OPENCLOUD_USERNAME=lvc-media-hub
OPENCLOUD_PASSWORD=ÄNDRA_MIG_till_opencloud_lösenord
OPENCLOUD_BASE_PATH=/Matcher

# Filuppladdning
MAX_FILE_SIZE_BYTES=10737418240
ALLOWED_FILE_TYPES=video/mp4,video/quicktime,video/x-matroska
ALLOWED_EXTENSIONS=.mp4,.mov,.mkv

# Signerade URL:er
SIGNED_URL_EXPIRY_SECONDS=3600

# Admin seed (används vid första körningen)
ADMIN_EMAIL=admin@lvcmediahub.com
ADMIN_PASSWORD=ÄNDRA_MIG_till_ett_starkt_lösenord
ADMIN_NAME=Admin
