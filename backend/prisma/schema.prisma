// ===========================================
// LVC Media Hub — Databasschema (Prisma + SQLite)
// ===========================================
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          String         @default("viewer") // admin, uploader, viewer
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  videos        Video[]
  loginAttempts LoginAttempt[]
  @@index([email])
}
model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  isRevoked   Boolean  @default(false)
  @@index([userId])
  @@index([tokenHash])
}
model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique  // t.ex. "LVC Dam", "LVC Herr"
  createdAt DateTime @default(now())
  seasons   Season[]
  videos    Video[]
}
model Season {
  id        Int      @id @default(autoincrement())
  name      String   // t.ex. "25/26", "24/25"
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  videos    Video[]
  @@unique([name, teamId])
}
model Video {
  id            String   @id @default(uuid())
  title         String
  opponent      String
  matchDate     DateTime
  description   String?
  fileName      String
  filePath      String
  fileSize      BigInt
  mimeType      String
  thumbnailPath String?
  dvwPath       String?
  videoOffset   Int      @default(0)
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  teamId        Int?
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  seasonId      Int?
  season        Season?  @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([matchDate])
  @@index([opponent])
  @@index([teamId])
  @@index([seasonId])
}
model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}
