// ===========================================
// LVC Media Hub — Databasschema (Prisma + SQLite)
// ===========================================

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  username      String         @unique
  name          String
  passwordHash  String
  role          String         @default("viewer")
  jerseyNumber  Int?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  refreshTokens RefreshToken[]
  videos        Video[]
  loginAttempts LoginAttempt[]
  teams         UserTeam[]
  coachReviews  CoachReview[] @relation("CoachReviews")
  playerReviews CoachReview[] @relation("PlayerReviews")

  @@index([email])
  @@index([username])
}

model InviteToken {
  id        String   @id @default(uuid())
  token     String   @unique
  role      String   @default("viewer")
  expiresAt DateTime
  maxUses   Int      @default(1)
  useCount  Int      @default(0)
  createdBy String
  createdAt DateTime @default(now())

  @@index([token])
}

model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  isRevoked   Boolean  @default(false)

  @@index([userId])
  @@index([tokenHash])
}

model Team {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  thumbnailPath String?
  createdAt     DateTime @default(now())
  seasons   Season[]
  videos    Video[]
  thumbnails ThumbnailLibrary[]
  members   UserTeam[]
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  videos    Video[]

  @@unique([name, teamId])
}

model Video {
  id            String   @id @default(uuid())
  title         String
  opponent      String
  matchDate     DateTime
  description   String?
  fileName      String
  filePath      String
  fileSize      BigInt
  mimeType      String
  thumbnailPath String?
  dvwPath       String?
  secondaryFilePath String?
  videoOffset   Int      @default(0)
  deletedAt    DateTime?
  deletedById  String?
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  teamId        Int?
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  seasonId      Int?
  season        Season?  @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([matchDate])
  @@index([opponent])
  @@index([teamId])
  @@index([seasonId])
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model ChangelogEntry {
  id        String   @id @default(uuid())
  version   String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThumbnailLibrary {
  id        String   @id @default(uuid())
  name      String
  filePath  String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, teamId])
  @@index([teamId])
}

model UserTeam {
  userId    String
  teamId    Int
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@id([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model CoachReview {
  id             String    @id @default(uuid())
  videoId        String
  actionIndex    Int
  coachId        String
  playerId       String
  comment        String
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
  coach          User      @relation("CoachReviews", fields: [coachId], references: [id], onDelete: Cascade)
  player         User      @relation("PlayerReviews", fields: [playerId], references: [id], onDelete: Cascade)
  @@index([coachId])
  @@index([playerId])
  @@index([videoId])
}
